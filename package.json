{
  "name": "lensiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build:worker": "esbuild scripts/audit-worker.ts --bundle --platform=node --format=cjs --outfile=dist/audit-worker.cjs --external:playwright --external:lighthouse --external:chrome-launcher --external:@supabase/supabase-js --external:zod --tsconfig=tsconfig.json",
    "worker": "npm run build:worker && node dist/audit-worker.cjs",
    "worker:once": "npm run build:worker && node dist/audit-worker.cjs --once",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.52.1",
    "@tailwindcss/postcss": "^4.1.11",
    "chrome-launcher": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lighthouse": "^12.8.2",
    "lucide-react": "^0.525.0",
    "next": "16.2.10",
    "playwright": "^1.54.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
